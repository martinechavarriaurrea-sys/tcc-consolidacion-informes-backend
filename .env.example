# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

# â”€â”€ App â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
APP_ENV=development                        # development | production
APP_SECRET_KEY=cambia-esto-con-openssl-rand-hex-32
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR

# Credenciales del administrador (login del frontend)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tcc2024
JWT_EXPIRE_HOURS=24

# â”€â”€ Base de datos â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
DATABASE_URL=postgresql+asyncpg://tcc_user:tcc_pass@localhost:5432/tcc_informes
DATABASE_ECHO=false

# Variables usadas por docker-compose para crear el contenedor de PostgreSQL
POSTGRES_USER=tcc_user
POSTGRES_PASSWORD=tcc_pass
POSTGRES_DB=tcc_informes

# â”€â”€ TCC Integration â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Modo: "scraping" (Playwright) | "api" (cuando TCC habilite API pÃºblica)
TCC_INTEGRATION_MODE=web
TCC_ENABLE_WEB_FALLBACK=true
TCC_BASE_URL=https://tcc.com.co
TCC_TRACKING_URL=https://tcc.com.co/courier/mensajeria/rastrear-envio/
TCC_TRACKING_QUERY_PARAM=guia
TCC_MIN_HTML_LENGTH=300
TCC_REQUEST_TIMEOUT=30
TCC_MAX_RETRIES=3
TCC_RETRY_DELAY=2.0

# Si TCC habilita una API REST en el futuro:
TCC_API_BASE_URL=
TCC_API_KEY=
TCC_API_TRACKING_PATH=/tracking/{tracking_number}
TCC_API_HEALTH_PATH=/health
TCC_API_AUTH_SCHEME=Bearer

# â”€â”€ Email SMTP â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Para Gmail usar App Password (no la contraseÃ±a normal)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@asteco.com.co
SMTP_PASSWORD=tu-app-password-aqui
SMTP_USE_TLS=true
EMAIL_FROM_NAME=Sistema TCC ASTECO
EMAIL_FROM_ADDRESS=noreply@asteco.com.co

# Reintentos de envÃ­o de correo (backoff exponencial)
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=5.0

# â”€â”€ Scheduler â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Los horarios de seguimiento diario (07:00, 12:00, 16:00) y consolidado
# semanal (lunes 07:00) estÃ¡n hardcodeados en app/jobs/scheduler.py
# como requisito de negocio no configurable.
#
# Solo es configurable el intervalo de verificaciÃ³n de alertas:
ALERT_CHECK_INTERVAL_MINUTES=30

# â”€â”€ Alertas â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# NÃºmero de horas sin movimiento para disparar alerta
ALERT_NO_MOVEMENT_HOURS=72

# â”€â”€ Reportes â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Directorio donde se guardan los archivos Excel y PDF generados
# En Docker: usar /app/reports (montado como volumen)
REPORTS_OUTPUT_DIR=./reports
